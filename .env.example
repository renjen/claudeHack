# Anthropic — Claude API (Haiku for /extract, Sonnet for /analyze + /generate-letter)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=anthropic-api-key-here

# OpenAI — embeddings for ChromaDB (text-embedding-3-small)
# Also fallback for Whisper if Groq is unavailable
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Groq — primary Whisper provider (whisper-large-v3-turbo, ~10x faster than OpenAI Whisper API)
# https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Auth — JWT signing secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# Change this before any non-local deployment
JWT_SECRET=change-me-in-production-please